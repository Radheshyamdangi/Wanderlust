<% layout("/layouts/boilerplate") %>
<%
const getRatingTier = (rating) => {
   if (rating >= 4.5) return "high";
   if (rating >= 3) return "medium";
   return "low";
};
const ownerId = listing.owner && listing.owner._id ? String(listing.owner._id) : "";
const currentUserId = currUser ? String(currUser._id) : "";
const isOwner = ownerId && currentUserId && ownerId === currentUserId;
const isAdmin = currUser && currUser.role === "admin";
const canEdit = currUser && (isAdmin || isOwner);
const canBook = currUser && currUser.role === "user" && !isOwner;
%>
<section class="detail-hero" data-category="<%= listing.category %>">
   <div class="detail-copy">
      <span class="eyebrow"><%= listing.category %> escape</span>
      <h1><%= listing.title %></h1>
      <div class="detail-meta-row">
         <span><i class="fa-solid fa-location-dot"></i> <%= listing.location %>, <%= listing.country %></span>
         <span class="rating-pill" data-rating-tier="<%= getRatingTier(listing.ratingAverage || 0) %>"><i class="fa-solid fa-star"></i> <%= listing.ratingAverage || 0 %> (<%= listing.reviewCount %> reviews)</span>
         <span><i class="fa-solid fa-user-group"></i> Up to <%= listing.maxGuests %> guests</span>
      </div>
      <p><%= listing.description %></p>
      <div class="host-chip">
         <span class="profile-avatar"><%= ((listing.owner && (listing.owner.fullName || listing.owner.username)) || 'W').slice(0, 1).toUpperCase() %></span>
         <div>
            <strong><%= listing.owner ? (listing.owner.fullName || listing.owner.username) : 'WanderLust Host' %></strong>
            <small><%= listing.owner ? listing.owner.role : 'host' %></small>
         </div>
      </div>
   </div>
   <div class="detail-media-card">
      <div class="media-shell loading-shell detail-media-shell">
         <img src="<%= listing.image?.url %>" alt="<%= listing.title %>" class="listing-image detail-image">
      </div>
      <div class="detail-price-bar">
         <strong>Rs. <%= listing.price.toLocaleString('en-IN') %></strong>
         <span>per night</span>
      </div>
   </div>
</section>

<section class="detail-grid">
   <article class="detail-panel">
      <div class="panel-heading">
         <h2>About this stay</h2>
         <span class="category-pill" data-category="<%= listing.category %>"><%= listing.category %></span>
      </div>
      <p><%= listing.description %></p>
      <div class="detail-points">
         <div>
            <strong>Best for</strong>
            <span><%= listing.category %> travelers</span>
         </div>
         <div>
            <strong>Capacity</strong>
            <span><%= listing.maxGuests %> guests</span>
         </div>
         <div>
            <strong>Location</strong>
            <span><%= listing.location %>, <%= listing.country %></span>
         </div>
      </div>
      <% if (canEdit || isAdmin) { %>
         <div class="detail-actions">
            <% if (canEdit) { %>
               <a href="/listings/<%= listing._id %>/edit" class="btn btn-outline-dark">Edit listing</a>
            <% } %>
            <% if (isAdmin) { %>
               <form method="POST" action="/listings/<%= listing._id %>/<%= listing.slug %>?_method=DELETE">
                  <button class="btn btn-danger" type="submit">Delete listing</button>
               </form>
            <% } %>
         </div>
      <% } %>
   </article>
   <aside class="detail-panel booking-panel">
      <span class="eyebrow">Reservation flow</span>
      <h2>Plan your stay</h2>
      <p>Check price, availability windows, and book without leaving the listing experience.</p>
      <div class="booking-summary">
         <div>
            <strong>Nightly rate</strong>
            <span>Rs. <%= listing.price.toLocaleString('en-IN') %></span>
         </div>
         <div>
            <strong>Guests</strong>
            <span>Up to <%= listing.maxGuests %></span>
         </div>
      </div>
      <% if (canBook) { %>
         <a class="btn btn-primary w-100" href="/listings/<%= listing._id %>/bookings/new">Book this property</a>
      <% } else if (!currUser) { %>
         <a class="btn btn-primary w-100" href="/login">Log in to book</a>
      <% } else if (currUser.role !== 'user') { %>
         <p class="helper-copy">Bookings are reserved for traveler accounts.</p>
      <% } %>
      <% if (bookedDateRanges.length) { %>
         <div class="booking-windows">
            <strong>Upcoming booked dates</strong>
            <ul>
               <% bookedDateRanges.forEach((range) => { %>
                  <li><%= new Date(range.checkIn).toLocaleDateString('en-IN') %> to <%= new Date(range.checkOut).toLocaleDateString('en-IN') %></li>
               <% }) %>
            </ul>
         </div>
      <% } %>
   </aside>
</section>

<section class="section-block">
   <div class="section-head">
      <div>
         <span class="eyebrow">Guest reviews</span>
         <h2>What travelers are saying</h2>
      </div>
   </div>
   <% if (currUser) { %>
      <form action="/listings/<%= listing._id %>/reviews" method="POST" novalidate class="review-form needs-validation detail-panel">
         <div class="panel-heading">
            <h3>Leave a review</h3>
            <span class="helper-copy">Share the experience in a way that helps future travelers.</span>
         </div>
         <div class="mb-3 mt-3">
            <label for="rating" class="form-label">Rating</label>
            <fieldset class="starability-slot">
               <input type="radio" id="first-rate1" name="review[rating]" value="1" />
               <label for="first-rate1" title="Terrible">1 star</label>
               <input type="radio" id="first-rate2" name="review[rating]" value="2" />
               <label for="first-rate2" title="Not good">2 stars</label>
               <input type="radio" id="first-rate3" name="review[rating]" value="3" checked />
               <label for="first-rate3" title="Average">3 stars</label>
               <input type="radio" id="first-rate4" name="review[rating]" value="4" />
               <label for="first-rate4" title="Very good">4 stars</label>
               <input type="radio" id="first-rate5" name="review[rating]" value="5" />
               <label for="first-rate5" title="Amazing">5 stars</label>
            </fieldset>
         </div>
         <div class="mb-3 mt-3">
            <label for="comment" class="form-label">Comments</label>
            <textarea name="review[comment]" id="comment" rows="4" class="form-control" required></textarea>
            <div class="invalid-feedback">Please add a short review.</div>
         </div>
         <button class="btn btn-outline-dark" type="submit">Submit review</button>
      </form>
   <% } %>

   <div class="review-grid">
      <% if (!listing.reviews.length) { %>
         <article class="empty-state compact-empty">
            <i class="fa-regular fa-message"></i>
            <h3>No reviews yet</h3>
            <p>This listing is fresh on the platform. The first review can set the tone.</p>
         </article>
      <% } %>
      <% listing.reviews.forEach((review) => { %>
         <%
         const reviewAuthorId = review.author && review.author._id ? String(review.author._id) : "";
         const canDeleteReview = currUser && (isAdmin || reviewAuthorId === currentUserId);
         %>
         <article class="detail-panel review-card">
            <div class="panel-heading">
               <div>
                  <h3><%= review.author ? (review.author.fullName || review.author.username) : 'Traveler' %></h3>
                  <p class="helper-copy"><%= review.author ? review.author.role : 'user' %></p>
               </div>
               <p class="starability-result card-text" data-rating="<%= review.rating %>"></p>
            </div>
            <p><%= review.comment %></p>
            <% if (canDeleteReview) { %>
               <form method="POST" action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE">
                  <button class="btn btn-sm btn-outline-danger" type="submit">Delete review</button>
               </form>
            <% } %>
         </article>
      <% }) %>
   </div>
</section>

<% if (relatedListings.length) { %>
   <section class="section-block">
      <div class="section-head">
         <div>
            <span class="eyebrow">Keep exploring</span>
            <h2>More in <%= listing.category %></h2>
         </div>
      </div>
      <div class="listing-grid related-grid">
         <% relatedListings.forEach((related) => { %>
            <article class="listing-card reveal-card" data-category="<%= related.category %>">
               <a href="<%= related.seoPath %>" class="listing-card-link">
                  <div class="media-shell loading-shell">
                     <img src="<%= related.image?.url %>" alt="<%= related.title %>" class="listing-image">
                  </div>
                  <div class="listing-card-body">
                     <div class="listing-card-topline">
                        <span class="category-pill" data-category="<%= related.category %>"><%= related.category %></span>
                        <span class="rating-pill" data-rating-tier="<%= getRatingTier(related.ratingAverage || 0) %>"><i class="fa-solid fa-star"></i> <%= related.ratingAverage || 0 %></span>
                     </div>
                     <h3><%= related.title %></h3>
                     <p><%= related.location %>, <%= related.country %></p>
                  </div>
               </a>
            </article>
         <% }) %>
      </div>
   </section>
<% } %>
