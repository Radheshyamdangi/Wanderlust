<% layout("/layouts/boilerplate") %>
<section class="form-shell">
   <div class="form-header">
      <span class="eyebrow">Host workflow</span>
      <h1>Create a new listing</h1>
      <p>Publish a stay with structured travel details, category placement, and booking-ready information.</p>
   </div>
   <form method="POST" action="/listings" novalidate class="needs-validation form-card" enctype="multipart/form-data">
      <div class="form-grid two-col">
         <div class="form-field full-span">
            <label for="title" class="form-label">Title</label>
            <input id="title" name="listing[title]" type="text" placeholder="Ocean-facing villa in Goa" class="form-control" required>
            <div class="invalid-feedback">Please enter a title.</div>
         </div>
         <div class="form-field full-span">
            <label for="description" class="form-label">Description</label>
            <textarea id="description" name="listing[description]" placeholder="Describe the experience, ambience, and what makes the stay special." class="form-control" rows="5" required></textarea>
            <div class="invalid-feedback">Please add a description.</div>
         </div>
         <div class="form-field">
            <label for="category" class="form-label">Category</label>
            <select id="category" name="listing[category]" class="form-select" required>
               <% categories.forEach((category) => { %>
                  <option value="<%= category %>"><%= category %></option>
               <% }) %>
            </select>
         </div>
         <div class="form-field">
            <label for="maxGuests" class="form-label">Max guests</label>
            <input id="maxGuests" name="listing[maxGuests]" type="number" min="1" max="12" class="form-control" value="2" required>
         </div>
         <div class="form-field full-span">
            <label for="image" class="form-label">Upload listing image</label>
            <input id="image" name="listing[image]" type="file" class="form-control" required>
         </div>
         <div class="form-field">
            <label for="price" class="form-label">Price per night</label>
            <input id="price" name="listing[price]" placeholder="8500" type="number" min="0" class="form-control" required>
         </div>
         <div class="form-field">
            <label for="country" class="form-label">Country</label>
            <input id="country" name="listing[country]" placeholder="India" type="text" class="form-control" required>
         </div>
         <div class="form-field full-span">
            <label for="location" class="form-label">Location</label>
            <input id="location" name="listing[location]" placeholder="North Goa" type="text" class="form-control" required>
         </div>
      </div>
      <button class="btn btn-primary btn-wide mt-4" type="submit">Publish listing</button>
   </form>
</section>
