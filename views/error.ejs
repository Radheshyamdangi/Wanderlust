<% layout("/layouts/boilerplate") %>
<section class="error-shell">
   <div class="error-card">
      <span class="eyebrow">Something needs attention</span>
      <h1><%= message %></h1>
      <p>The request could not be completed right now. You can head back to the main search experience and keep moving.</p>
      <div class="error-actions">
         <a class="btn btn-primary" href="/listings">Explore listings</a>
         <a class="btn btn-outline-secondary" href="/">Go home</a>
      </div>
   </div>
</section>
