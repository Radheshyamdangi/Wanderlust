<% if (success && success.length) { %>
   <div class="flash-stack">
      <div class="alert alert-success flash-card alert-dismissible fade show" role="alert">
         <i class="fa-solid fa-circle-check"></i>
         <div>
            <strong>Success</strong>
            <p><%= success.join ? success.join(' ') : success %></p>
         </div>
         <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
      </div>
   </div>
<% } %>
<% if (error && error.length) { %>
   <div class="flash-stack">
      <div class="alert alert-danger flash-card alert-dismissible fade show" role="alert">
         <i class="fa-solid fa-triangle-exclamation"></i>
         <div>
            <strong>Heads up</strong>
            <p><%= error.join ? error.join(' ') : error %></p>
         </div>
         <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
      </div>
   </div>
<% } %>
